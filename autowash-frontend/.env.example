# ============================================================
# AutoWash Frontend – Environment Configuration
# ============================================================
# Copy file này thành .env.local trước khi chạy:
#   cp .env.example .env.local
#
# Quy định cổng mặc định cho local development:
#   - Backend  (Spring Boot) : http://localhost:8080
#   - Frontend (Next.js)     : http://localhost:3000
# ============================================================

# URL gốc của Backend API (bao gồm /api/v1)
# Mặc định trỏ về backend local. Thay đổi khi deploy staging/production.
NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1
NEXT_PUBLIC_FRONTEND_URL=http://localhost:3000
